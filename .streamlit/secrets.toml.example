# Copy to secrets.toml and fill in. Streamlit Cloud users paste this into the
# "Secrets" editor in the app settings, not into a committed file.

# ---- LLM providers (all optional) ----
# Groq free tier powers the enrichment features (cloze, MC distractors,
# daily challenge, tutor chat) at zero cost. Without any key, the app
# still works fully as an offline dictionary + SRS.
GROQ_API_KEY = ""

# Optional paid Claude for the highest-quality tutor experience.
# Capped by LEXICO_DAILY_USD_CAP (default $0.25/day).
ANTHROPIC_API_KEY = ""

# ---- Supabase Postgres (optional) ----
# Omit in local dev to use SQLite at ~/.lexico/lexico.db.
# On Streamlit Cloud, set to your Supabase pooler connection string (IPv4).
[database]
url = ""

# ---- Authentication (optional) ----
# Omit in local dev to skip login. On Streamlit Cloud, defining
# [credentials] auto-enables authentication.
[credentials.usernames.demo]
name = "Demo User"
password = ""  # bcrypt hash; generate via streamlit_authenticator.Hasher
email = "demo@example.com"

[cookie]
name = "lexico_auth"
key = "change-me-to-a-random-string"
expiry_days = 30
